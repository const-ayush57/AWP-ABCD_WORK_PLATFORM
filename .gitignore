# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/

# ── Production / Build ────────────────────────────────────────────────────────
/build
/dist
/dist-release
/dist-release-*
/dist-v*
/.next-build
/.next-prod
/.next-release
/FINAL_APP_RELEASE
/node-runtime

# ── Environment & Secrets (NEVER commit these) ───────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt

# ── Database (contains user data & hashed passwords) ─────────────────────────
prisma/*.db
prisma/*.db-shm
prisma/*.db-wal
prisma/*.sqlite
prisma/*.sqlite3

# ── Prisma migrations (generated — not part of source) ───────────────────────
# Remove this line if you want to track migrations in git
prisma/migrations/

# ── Misc / OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── Debug / Logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Scripts / CI tooling (local only) ────────────────────────────────────────
/scripts

# ── Dev artefacts & internal docs (not for public repo) ──────────────────────
diff_to_review.txt
ADMIN_MANAGEMENT_SYSTEM.md
ADMIN_USER_GUIDE.md
DATA_FLOW_SEPARATION.md
PHASE2_TEST_REPORT.md
SMTP_SETUP_GUIDE.md

# ── Identity / Network fingerprint files (machine-specific) ──────────────────
/identity/
*.network-hash
*.identity

# ── Electron / Packaged App Artifacts ────────────────────────────────────────
/release/
/dist-electron/
build-log.txt
lint_output.txt
lint_results.json
package.json.md5

